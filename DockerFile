# Use slim Node
FROM node:20-slim

# Prevent Puppeteer from downloading Chrome during npm install
ENV PUPPETEER_SKIP_DOWNLOAD=true
# Optional: helpful envs for runtime/path
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV CHROME_PATH=/usr/bin/chromium

# Install Chromium (system package) and minimal deps
RUN apt-get update && \
    apt-get install -y --no-install-recommends chromium ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files first to leverage Docker cache
COPY package*.json ./

# Install dependencies (use npm ci for reproducibility)
RUN npm ci --unsafe-perm

# Copy the rest of the source
COPY . .

# Expose port if you run a web server (adjust if not needed)
EXPOSE 3000

# Start command — change server.js to your actual entry
CMD ["node", "server.js"]
